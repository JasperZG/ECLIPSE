\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {\textsc  {CircularODE}{} dynamics and \textsc  {VulnCausal}{} vulnerability discovery.} (a) \textbf  {Trajectory prediction}: \textsc  {CircularODE}{} predicts ecDNA copy number evolution under treatment with 95\% confidence intervals (MSE $= 0.014$). (b) \textbf  {Physics validation}: Learned variance tracks theoretical binomial segregation ($\text  {Var} = z/4$) with $r = 0.993$. (c) \textbf  {External validation}: Correlation $> 0.997$ on published Lange et al.\ data (GBM39, TR14 cell lines). (d) \textbf  {Vulnerability discovery}: \textsc  {VulnCausal}{} achieves 29.8\% validation rate, $3.7\times $ higher than differential CRISPR.}}{4}{figure.caption.11}\protected@file@percent }
\newlabel{fig:dynamics}{{3}{4}{\textbf {\circularode {} dynamics and \vulncausal {} vulnerability discovery.} (a) \textbf {Trajectory prediction}: \circularode {} predicts ecDNA copy number evolution under treatment with 95\% confidence intervals (MSE $= 0.014$). (b) \textbf {Physics validation}: Learned variance tracks theoretical binomial segregation ($\text {Var} = z/4$) with $r = 0.993$. (c) \textbf {External validation}: Correlation $> 0.997$ on published Lange et al.\ data (GBM39, TR14 cell lines). (d) \textbf {Vulnerability discovery}: \vulncausal {} achieves 29.8\% validation rate, $3.7\times $ higher than differential CRISPR}{figure.caption.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textbf  {Physics constraint ablation for \textsc  {CircularODE}{} on cross-treatment generalization.} Validation here tests generalization to unseen treatment regimes (harder than in-distribution test where $r = 0.993$). Varying $\lambda _{\text  {phys}}$ shows minimal impact; the no-physics baseline achieves comparable correlation.}}{4}{table.caption.12}\protected@file@percent }
\newlabel{tab:physics_ablation}{{5}{4}{\textbf {Physics constraint ablation for \circularode {} on cross-treatment generalization.} Validation here tests generalization to unseen treatment regimes (harder than in-distribution test where $r = 0.993$). Varying $\lambda _{\text {phys}}$ shows minimal impact; the no-physics baseline achieves comparable correlation}{table.caption.12}{}}
