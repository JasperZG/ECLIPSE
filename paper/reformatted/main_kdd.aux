\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces \textbf  {GSEA pathway enrichment for \textsc  {VulnCausal}{} vulnerability rankings.} Top pathways by normalized enrichment score (NES). Mitotic nuclear division and DNA replication show strongest enrichment, consistent with known ecDNA biology: ecDNA replicates extra copies (replication stress) and segregates aberrantly during mitosis.}}{4}{table.caption.13}\protected@file@percent }
\newlabel{tab:gsea}{{6}{4}{\textbf {GSEA pathway enrichment for \vulncausal {} vulnerability rankings.} Top pathways by normalized enrichment score (NES). Mitotic nuclear division and DNA replication show strongest enrichment, consistent with known ecDNA biology: ecDNA replicates extra copies (replication stress) and segregates aberrantly during mitosis}{table.caption.13}{}}
