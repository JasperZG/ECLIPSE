\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {\textsc  {CircularODE}{} dynamics and \textsc  {VulnCausal}{} vulnerability discovery.} (a) \textbf  {Trajectory prediction}: \textsc  {CircularODE}{} predicts ecDNA copy number evolution under treatment with 95\% confidence intervals (MSE $= 0.014$). (b) \textbf  {Physics validation}: Learned variance tracks theoretical binomial segregation ($\text  {Var} = z/4$) with $r = 0.993$. (c) \textbf  {External validation}: Correlation $> 0.997$ on published Lange et al.\ data (GBM39, TR14 cell lines). (d) \textbf  {Vulnerability discovery}: \textsc  {VulnCausal}{} achieves 29.8\% validation rate, $3.7\times $ higher than differential CRISPR.}}{5}{figure.caption.7}\protected@file@percent }
\newlabel{fig:dynamics}{{3}{5}{\textbf {\circularode {} dynamics and \vulncausal {} vulnerability discovery.} (a) \textbf {Trajectory prediction}: \circularode {} predicts ecDNA copy number evolution under treatment with 95\% confidence intervals (MSE $= 0.014$). (b) \textbf {Physics validation}: Learned variance tracks theoretical binomial segregation ($\text {Var} = z/4$) with $r = 0.993$. (c) \textbf {External validation}: Correlation $> 0.997$ on published Lange et al.\ data (GBM39, TR14 cell lines). (d) \textbf {Vulnerability discovery}: \vulncausal {} achieves 29.8\% validation rate, $3.7\times $ higher than differential CRISPR}{figure.caption.7}{}}
\newlabel{fig:dynamics@cref}{{[figure][3][]3}{[1][4][]5}{}{}{}}
