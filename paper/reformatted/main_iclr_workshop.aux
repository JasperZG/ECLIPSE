\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {\textsc  {ecDNA-Former}{} formation prediction results.} (a) ROC curves comparing 5-fold CV performance: \textsc  {ecDNA-Former}{} (AUROC $0.729$) performs comparably to MLP baseline ($0.752$); removing dosage features improves to $0.812$. (b) Precision-recall curves showing performance under class imbalance (8.9\% positive rate). (c) Calibration plot with expected calibration error ECE$=$0.131. (d) Ablation analysis: removing expression hurts most ($-1.1$ pp); removing dosage \textit  {improves} AUROC by $+2.4$ pp, suggesting overfitting.}}{4}{figure.caption.5}\protected@file@percent }
\newlabel{fig:formation}{{2}{4}{\textbf {\former {} formation prediction results.} (a) ROC curves comparing 5-fold CV performance: \former {} (AUROC $0.729$) performs comparably to MLP baseline ($0.752$); removing dosage features improves to $0.812$. (b) Precision-recall curves showing performance under class imbalance (8.9\% positive rate). (c) Calibration plot with expected calibration error ECE$=$0.131. (d) Ablation analysis: removing expression hurts most ($-1.1$ pp); removing dosage \textit {improves} AUROC by $+2.4$ pp, suggesting overfitting}{figure.caption.5}{}}
\newlabel{fig:formation@cref}{{[figure][2][]2}{[1][3][]4}{}{}{}}
