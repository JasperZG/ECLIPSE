\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces \textbf  {Hyperparameter configuration for all \textsc  {Eclipse}{} modules.} Values selected via validation set performance. \textsc  {ecDNA-Former}{} uses 16 bottleneck tokens balancing expressivity and regularization. \textsc  {CircularODE}{} physics weight $\lambda _{\text  {phys}}=0.1$ enforces constraints without over-regularizing. \textsc  {VulnCausal}{} IRM penalty $\lambda =1.0$ with linear annealing ensures stable training.}}{11}{table.caption.20}\protected@file@percent }
